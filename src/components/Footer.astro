<footer class="bg-olive-dark text-cream/90 relative overflow-hidden">
  <!-- Subtle layered background -->
  <div class="absolute inset-0 bg-gradient-to-br from-olive-dark via-[#2a3824] to-olive-dark opacity-50"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-terracotta/20 to-transparent"></div>

  <div class="max-w-[1280px] mx-auto px-6 md:px-8 lg:px-12 pt-20 pb-12 lg:pt-24 lg:pb-16 relative z-10">
    <!-- Main grid: 4 columns on desktop, stack on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-10">

      <!-- Brand -->
      <div>
        <a href="/" class="font-serif text-2xl text-cream inline-block mb-4">
          Kin <span class="text-terracotta-light">&amp;</span> Grain
        </a>
        <p class="text-sm leading-relaxed text-cream/60 max-w-[28ch] mb-6">
          Specialty coffee &amp; wholesome food in the heart of Sydney. Made with care since 2019.
        </p>
        <div class="flex items-center gap-2">
          <div class="w-8 h-px bg-terracotta-light/30"></div>
          <div class="w-1.5 h-1.5 rounded-full bg-terracotta-light/30"></div>
          <div class="w-8 h-px bg-terracotta-light/30"></div>
        </div>
      </div>

      <!-- Opening Hours -->
      <div>
        <h4 class="font-serif text-lg text-cream mb-5">Hours</h4>
        <dl class="space-y-3 text-sm">
          <div class="flex justify-between gap-4">
            <dt class="text-cream/55">Monday – Friday</dt>
            <dd class="text-cream/90 tabular-nums">6:30am – 4pm</dd>
          </div>
          <div class="flex justify-between gap-4">
            <dt class="text-cream/55">Saturday – Sunday</dt>
            <dd class="text-cream/90 tabular-nums">7:30am – 3pm</dd>
          </div>
        </dl>
      </div>

      <!-- Location & Contact -->
      <div>
        <h4 class="font-serif text-lg text-cream mb-5">Contact</h4>
        <address class="not-italic space-y-3 text-sm">
          <p class="text-cream/55">22 Market Street<br>Sydney NSW 2000</p>
          <p>
            <a href="tel:0295553421" class="text-cream/90 hover:text-terracotta-light transition-colors duration-200">
              02 9555 3421
            </a>
          </p>
          <p>
            <a href="mailto:hello@kinandgrain.com.au" class="text-cream/90 hover:text-terracotta-light transition-colors duration-200">
              hello@kinandgrain.com.au
            </a>
          </p>
        </address>
      </div>

      <!-- Follow & Newsletter -->
      <div>
        <h4 class="font-serif text-lg text-cream mb-5">Follow Us</h4>
        <a
          href="https://instagram.com/kinandgrain"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm text-cream/80 hover:text-terracotta-light transition-colors duration-200 mb-8"
