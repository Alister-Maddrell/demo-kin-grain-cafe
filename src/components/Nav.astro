---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
};
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background-color: var(--color-stone);">
  <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12">
    <div class="flex items-center justify-between h-[72px]">
      <!-- Logo -->
      <a href="/" class="shrink-0 group">
        <span class="font-serif text-[1.4rem] lg:text-[1.6rem] tracking-tight transition-colors duration-300 group-hover:text-terracotta" style="color: var(--color-ink);">
          Kin <span class="text-terracotta">&amp;</span> Grain
        </span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-10">
        {[
          { href: '/', label: 'Home' },
          { href: '/menu', label: 'Menu' },
          { href: '/contact', label: 'Contact' },
        ].map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-[0.8125rem] font-medium tracking-[0.06em] uppercase transition-colors duration-300 link-underline',
              isActive(href) ? 'text-terracotta' : 'text-ink hover:text-terracotta',
            ]}
          >
            {label}
          </a>
        ))}
      </div>

      <!-- CTA -->
      <a
        href="/reservation"
        class="hidden md:inline-flex items-center gap-2 px-5 py-2 text-[0.8125rem] font-medium tracking-[0.04em] rounded-[10px] transition-all duration-300 bg-terracotta text-white hover:bg-terracotta-dark btn-press"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        Reserve
      </a>

      <!-- Mobile menu toggle -->
      <button id="nav-toggle" class="md:hidden relative w-8 h-8 flex items-center justify-center" aria-label="Toggle menu" aria-expanded="false">
        <span class="sr-only">Menu</span>
        <div class="flex flex-col gap-[5px] transition-all duration-300" id="hamburger">
          <span class="block w-5 h-[1.5px] rounded-full transition-all duration-300 origin-center" style="background-color: var(--color-ink);"></span>
          <span class="block w-5 h-[1.5px] rounded-full transition-all duration-300" style="background-color: var(--color-ink);"></span>
          <span class="block w-3.5 h-[1.5px] rounded-full transition-all duration-300 ml-auto" style="background-color: var(--color-ink);"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="md:hidden overflow-hidden max-h-0 transition-[max-height] duration-300 ease-out border-t" style="background-color: var(--color-stone); border-color: var(--color-warm-border);">
    <div class="px-6 py-8 flex flex-col gap-6">
      {[
        { href: '/', label: 'Home' },
        { href: '/menu', label: 'Menu' },
        { href: '/contact', label: 'Contact' },
        { href: '/reservation', label: 'Reservation' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'font-serif text-[1.25rem]',
            isActive(href) ? 'text-terracotta' : 'text-ink',
          ]}
        >
          {label}
        </a>
      ))}
      <a href="/reservation" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-terracotta text-white text-sm font-medium rounded-[10px] hover:bg-terracotta-dark transition-colors mt-2 btn-press">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
        Reserve a Table
      </a>
    </div>
  </div>
</nav>

<!-- Spacer to offset fixed nav -->
<div class="h-[72px]"></div>

<script>
  const nav = document.getElementById('main-nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bars = document.querySelectorAll('#hamburger span');

  let menuOpen = false;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      nav.classList.add('nav-scrolled');
    } else {
      nav.classList.remove('nav-scrolled');
    }
  });

  toggle.addEventListener('click', () => {
    menuOpen = !menuOpen;
    toggle.setAttribute('aria-expanded', String(menuOpen));

    if (menuOpen) {
      menu.style.maxHeight = menu.scrollHeight + 'px';
      (bars[0] as HTMLElement).style.transform = 'rotate(45deg) translate(2px, 5px)';
      (bars[1] as HTMLElement).style.opacity = '0';
      (bars[2] as HTMLElement).style.transform = 'rotate(-45deg) translate(2px, -5px)';
      (bars[2] as HTMLElement).style.width = '1.25rem';
    } else {
      menu.style.maxHeight = '0';
      (bars[0] as HTMLElement).style.transform = '';
      (bars[1] as HTMLElement).style.opacity = '1';
      (bars[2] as HTMLElement).style.transform = '';
      (bars[2] as HTMLElement).style.width = '';
    }
  });
</script>
