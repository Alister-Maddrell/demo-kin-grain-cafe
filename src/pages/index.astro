---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Specialty Coffee & All-Day Brunch | Kin & Grain Sydney CBD"
  description="Start your morning with single-origin coffee and scratch-made brunch at Kin & Grain, 22 Market Street Sydney CBD. View our seasonal menu and order catering today."
>

  <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden kins-hero-section" style="background-color: var(--color-ink);">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1920&h=1080&fit=crop"
        alt="Cozy cafe interior with warm lighting"
        class="w-full h-full object-cover kins-hero-img"
      />
      <div class="absolute inset-0 kins-hero-overlay"></div>
    </div>

    <!-- Grain overlay -->
    <div class="grain-overlay absolute inset-0"></div>

    <!-- Floating polaroid images -->
    <div class="absolute top-[15%] right-[8%] kins-polaroid kins-polaroid-1 hidden lg:block">
      <div class="kins-polaroid-inner">
        <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=400&h=400&fit=crop" alt="Pour-over coffee" class="w-full h-full object-cover" />
      </div>
      <p class="kins-polaroid-caption">Morning Ritual</p>
    </div>
    <div class="absolute bottom-[18%] right-[15%] kins-polaroid kins-polaroid-2 hidden lg:block">
      <div class="kins-polaroid-inner">
        <img src="https://images.unsplash.com/photo-1525351484163-7529414344d8?w=400&h=400&fit=crop" alt="Brunch plate" class="w-full h-full object-cover" />
      </div>
      <p class="kins-polaroid-caption">The Kin Bowl — $22</p>
    </div>

    <!-- Content — editorial full-bleed distributed layout -->
    <div class="relative z-10 kins-hero-canvas">

      <!-- TOP ZONE: Overline -->
      <div class="kins-hero-zone-top kins-hero-reveal" style="--delay: 0">
        <p class="overline !text-terracotta-light !mb-0">Sydney CBD — Est. 2019</p>
      </div>

      <!-- MIDDLE ZONE: Heading + description -->
      <div class="kins-hero-zone-mid">
        <h1 class="kins-hero-heading kins-hero-reveal" style="color: #fff; --delay: 1">
          Your Morning<br/>
          <span class="kins-hero-script">Ritual,</span><br/>
          Perfected.
        </h1>
        <p class="kins-hero-desc kins-hero-reveal" style="color: rgba(255,255,255,0.75); --delay: 2">
          Single-origin coffee &amp; scratch-made brunch on Market Street.
        </p>
      </div>

      <!-- BOTTOM ZONE: CTAs + trust strip -->
      <div class="kins-hero-zone-bot">
        <div class="flex gap-3 kins-hero-ctas kins-hero-reveal" style="--delay: 3">
          <a href="/menu" class="btn-primary !bg-terracotta hover:!bg-terracotta-dark">
            View Menu
          </a>
          <a href="/contact" class="btn-outline !border-white/30 !text-white hover:!border-terracotta hover:!text-terracotta">
            Visit Us
          </a>
        </div>

        <!-- Trust strip -->
        <div class="kins-trust-strip kins-hero-reveal" style="--delay: 4">
          <span class="text-terracotta">★★★★★</span>
          <span class="kins-trust-text">4.9 Google</span>
          <span class="kins-trust-dot"></span>
          <span class="kins-trust-text">Open 7 days</span>
          <span class="kins-trust-dot"></span>
          <span class="kins-trust-text">22 Market St</span>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══ OUR STORY ══════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-24 md:py-32 lg:py-[130px] relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-center">

        <!-- Image — 5 columns -->
        <div class="lg:col-span-5 reveal">
          <div class="relative">
            <div class="rounded-lg overflow-hidden img-editorial shadow-lg shadow-ink/6">
              <img
                src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?w=800&h=1000&fit=crop"
                alt="Barista carefully preparing a pour-over coffee behind the counter"
                class="w-full aspect-[4/5] object-cover img-sepia"
              />
            </div>
          </div>
          <!-- Quiet caption below image -->
          <p class="text-center mt-6 font-serif text-sm italic" style="color: var(--color-muted);">
            "Every cup tells a story. Every plate, a labour of love."
          </p>
        </div>

        <!-- Text — 7 columns -->
        <div class="lg:col-span-7 reveal">
          <p class="overline mb-4">Our Story</p>
          <h2 class="mb-8">From Bean to Bowl — How Your Food Gets to the Table</h2>
          <div class="max-w-[52ch]">
            <p class="leading-relaxed mb-6 drop-cap" style="color: var(--color-muted);">
              It started in 2019 with a worn espresso machine and a handful of recipes passed down through family kitchens. Seven years on, you'll still find us on Market Street in Sydney CBD — sourcing beans directly from single-origin farms, partnering with 12 local growers, and making everything from our sourdough to our dukkah by hand.
            </p>
            <p class="leading-relaxed" style="color: var(--color-muted);">
              Whether you're a Wynyard commuter grabbing your morning flat white or lingering over a long brunch with friends, you'll taste the difference in every bite. No shortcuts, no pre-mixes — just honest food and properly brewed coffee made for you.
            </p>
          </div>

          <div class="brush-stroke mt-10"></div>

          <!-- Stats -->
          <div class="mt-10 flex gap-12 lg:gap-16">
            <div>
              <p class="font-serif text-4xl text-terracotta font-bold mb-1">7+</p>
              <p class="text-xs uppercase tracking-[0.12em] font-semibold" style="color: var(--color-ink-light);">Years in Sydney CBD</p>
            </div>
            <div>
              <p class="font-serif text-4xl text-terracotta font-bold mb-1">12</p>
              <p class="text-xs uppercase tracking-[0.12em] font-semibold" style="color: var(--color-ink-light);">Local Growers &amp; Suppliers</p>
            </div>
            <div>
              <p class="font-serif text-4xl text-terracotta font-bold mb-1">100%</p>
              <p class="text-xs uppercase tracking-[0.12em] font-semibold" style="color: var(--color-ink-light);">Made In-House</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ FEATURED MENU ══════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-stone);">
    <div class="grain-overlay absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-24 md:py-32 lg:py-[130px] relative z-10">

      <div class="text-center mb-16 lg:mb-20 reveal">
        <p class="overline mb-4">From the Kitchen</p>
        <h2 class="mb-4">Taste What Keeps Our Regulars Coming Back</h2>
        <p class="max-w-[42ch] mx-auto text-sm" style="color: var(--color-muted);">Seasonal produce, careful hands, and flavours you'll be thinking about long after your last bite.</p>
      </div>

      <!-- 3 featured cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">

        <!-- Card 1 -->
        <article class="group reveal stagger-1">
          <div class="overflow-hidden rounded-lg mb-6 img-editorial">
            <img src="https://images.unsplash.com/photo-1525351484163-7529414344d8?w=600&h=750&fit=crop" alt="Breakfast bowl with poached eggs, smashed avocado and fresh greens on sourdough" class="aspect-[4/5] w-full object-cover img-zoom img-sepia" />
          </div>
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="group-hover:text-terracotta transition-colors duration-300">The Kin Bowl</h3>
            <span class="text-terracotta font-bold text-xl shrink-0 mt-1 tabular-nums font-serif">$22</span>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
            Silky poached eggs nestled over smashed avo, scattered with house-made dukkah and tangy pickled radish, all on warm crusty sourdough. One bite and you'll see why it's our most-ordered dish.
          </p>
        </article>

        <!-- Card 2 — offset for editorial rhythm -->
        <article class="group md:mt-14 reveal stagger-2">
          <div class="overflow-hidden rounded-lg mb-6 img-editorial">
            <img src="https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=600&h=750&fit=crop" alt="Single origin pour-over coffee being brewed into a glass carafe" class="aspect-[4/5] w-full object-cover img-zoom img-sepia" />
          </div>
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="group-hover:text-terracotta transition-colors duration-300">Single Origin Pour Over</h3>
            <span class="text-terracotta font-bold text-xl shrink-0 mt-1 tabular-nums font-serif">$7</span>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
            Rotating single-origin beans from small-lot farms, brewed to order just for you. This month: Ethiopian Yirgacheffe — bright blueberry up front, velvety dark chocolate on the finish.
          </p>
        </article>

        <!-- Card 3 -->
        <article class="group reveal stagger-3">
          <div class="overflow-hidden rounded-lg mb-6 img-editorial">
            <img src="https://images.unsplash.com/photo-1512621776951-a57141f2eefd?w=600&h=750&fit=crop" alt="Colorful grain bowl with quinoa, roasted sweet potato and fresh vegetables" class="aspect-[4/5] w-full object-cover img-zoom img-sepia" />
          </div>
          <div class="flex items-start justify-between gap-4 mb-2">
            <h3 class="group-hover:text-terracotta transition-colors duration-300">Grain Bowl</h3>
            <span class="text-terracotta font-bold text-xl shrink-0 mt-1 tabular-nums font-serif">$19</span>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
            Warm quinoa tossed with honey-roasted sweet potato, drizzled in creamy tahini, topped with pepitas, crumbled feta, and crisp mixed greens. Hearty enough for lunch, light enough to feel great after.
          </p>
        </article>
      </div>

      <div class="text-center mt-16 lg:mt-20">
        <a href="/menu" class="link-underline font-semibold text-lg hover:text-terracotta transition-colors duration-300" style="color: var(--color-ink);">
          View Our Full Menu →
        </a>
      </div>
    </div>
  </section>


  <!-- ═══ LIFE AT THE CAFE ══════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-24 md:py-32 lg:py-[120px] relative z-10">

      <div class="text-center mb-12 lg:mb-16 reveal">
        <p class="overline mb-4">Life at the Cafe</p>
        <h2 class="mb-3">Step Inside Your New Favourite Spot</h2>
        <p class="max-w-[36ch] mx-auto text-sm font-serif italic" style="color: var(--color-muted);">Sunlit tables, the hiss of steam, and the warm smell of fresh sourdough</p>
      </div>

      <!-- Photo grid -->
      <div class="cafe-grid reveal">
        <div class="cafe-grid-item img-editorial">
          <img src="https://images.unsplash.com/photo-1559925393-8be0ec4767c8?w=600&h=600&fit=crop" alt="Customers enjoying coffee and conversation at a sunlit cafe table" class="img-sepia" />
        </div>
        <div class="cafe-grid-item cafe-grid-tall img-editorial hidden md:block">
          <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&h=1000&fit=crop" alt="Beautifully plated brunch dish with edible flowers and microgreens" class="img-sepia" />
        </div>
        <div class="cafe-grid-item img-editorial">
          <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=600&h=600&fit=crop" alt="Latte art in a ceramic cup viewed from above" class="img-sepia" />
        </div>
        <div class="cafe-grid-item img-editorial">
          <img src="https://images.unsplash.com/photo-1493770348161-369560ae357d?w=600&h=600&fit=crop" alt="Fresh seasonal ingredients and herbs arranged on a wooden cutting board" class="img-sepia" />
        </div>
        <div class="cafe-grid-item img-editorial md:hidden">
          <img src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&h=600&fit=crop" alt="Beautifully plated brunch dish with edible flowers and microgreens" class="img-sepia" />
        </div>
        <div class="cafe-grid-item img-editorial hidden md:block">
          <img src="https://images.unsplash.com/photo-1445116572660-236099ec97a0?w=600&h=600&fit=crop" alt="Barista pouring steamed milk into a coffee cup behind the counter" class="img-sepia" />
        </div>
      </div>

      <div class="text-center mt-10">
        <a
          href="https://instagram.com/kinandgrain"
          target="_blank"
          rel="noopener noreferrer"
          class="link-underline text-base font-semibold hover:text-terracotta transition-colors duration-300"
          style="color: var(--color-ink);"
        >
          Follow Your Morning Fix on Instagram @kinandgrain →
        </a>
      </div>
    </div>
  </section>


  <!-- ═══ EMAIL CAPTURE ══════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-stone);">
    <div class="grain-overlay absolute inset-0"></div>

    <div class="max-w-[640px] mx-auto px-6 md:px-8 py-24 md:py-32 lg:py-[130px] text-center relative z-10">
      <div class="reveal">
        <p class="overline mb-4">Stay Connected</p>
        <h2 class="mb-4">Get a Taste Before You Visit</h2>
        <p class="text-lg font-serif italic text-terracotta mb-2">Enjoy 10% off your first visit</p>
        <p class="leading-relaxed mb-10 max-w-[50ch] mx-auto" style="color: var(--color-muted);">
          Be the first to discover new seasonal dishes, limited-run coffee roasts, and events at our Market Street cafe. One short email a week — never spam, always worth opening.
        </p>

        <form id="email-capture" action="https://formspree.io/f/placeholder" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-[480px] mx-auto">
          <label for="email-capture-input" class="sr-only">Your email address</label>
          <input
            type="email"
            id="email-capture-input"
            name="email"
            placeholder="Your email address"
            required
            class="flex-1 px-5 py-3.5 border border-ink/15 rounded-[12px] text-sm placeholder-ink/40 transition-colors duration-300 shadow-sm"
            style="background-color: var(--color-cream); color: var(--color-ink);"
          />
          <button
            type="submit"
            class="btn-primary shrink-0"
          >
            Subscribe
          </button>
        </form>
        <p id="email-capture-msg" class="hidden mt-4 text-sm text-matcha font-medium">Welcome to the family! Check your inbox for your 10% off code.</p>
      </div>
    </div>
  </section>


  <!-- ═══ HOURS & LOCATION TEASER ════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-24 md:py-32 lg:py-[120px] relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-start reveal">

        <!-- Hours -->
        <div>
          <p class="overline mb-4">Hours</p>
          <h2 class="mb-8">Open Early, Seven Days — Your Table is Waiting</h2>
          <dl class="space-y-4 text-lg">
            <div class="flex justify-between items-baseline border-b pb-4" style="border-color: var(--color-warm-border);">
              <dt class="font-serif">Monday – Friday</dt>
              <dd class="tabular-nums font-medium">6:30am – 4pm</dd>
            </div>
            <div class="flex justify-between items-baseline">
              <dt class="font-serif">Saturday – Sunday</dt>
              <dd class="tabular-nums font-medium">7:30am – 3pm</dd>
            </div>
          </dl>

          <!-- Holiday Notice -->
          <div class="mt-8 card-hairline p-6">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-terracotta shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
              <div>
                <p class="text-sm font-semibold mb-0.5" style="color: var(--color-ink);">Easter 2026 Hours</p>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted);">We'll be closed Good Friday (3 April) and Easter Saturday. Back to normal hours from Easter Sunday — we can't wait to see you.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="md:pt-4">
          <p class="overline mb-4">Location</p>
          <h3 class="mb-4">22 Market Street</h3>
          <p class="mb-2" style="color: var(--color-muted);">Sydney NSW 2000</p>
          <p class="mb-8" style="color: var(--color-muted);">
            Between Clarence &amp; Kent Streets — a 5-minute walk from Wynyard Station or 7 minutes from Town Hall.
          </p>

          <!-- Map -->
          <div class="rounded-2xl overflow-hidden shadow-md mb-8 aspect-[16/9] border" style="background-color: var(--color-cream); border-color: var(--color-warm-border);">
            <iframe
              title="Kin & Grain location"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.8!2d151.205!3d-33.870!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae3c3b3b3b3b%3A0x0!2s22+Market+St%2C+Sydney+NSW+2000!5e0!3m2!1sen!2sau!4v1700000000000!5m2!1sen!2sau"
              width="100%"
              height="100%"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full"
            ></iframe>
          </div>

          <a
            href="/contact"
            class="btn-outline border-terracotta text-terracotta hover:bg-terracotta hover:text-white transition-all duration-300"
          >
            Get Directions &amp; Plan Your Visit
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const captureForm = document.getElementById('email-capture') as HTMLFormElement;
  const captureMsg = document.getElementById('email-capture-msg');

  captureForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    captureForm.classList.add('hidden');
    captureMsg?.classList.remove('hidden');
  });
</script>
