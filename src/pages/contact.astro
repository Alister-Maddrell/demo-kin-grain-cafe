---
import Layout from '../layouts/Layout.astro';

const events = [
  {
    title: 'Live Acoustic Fridays',
    description: 'Grab your lunch, settle in, and enjoy live local musicians every Friday 12 to 2pm. The perfect midday escape.',
    date: 'Every Friday',
    icon: '♪',
  },
  {
    title: 'Latte Art Workshop',
    description: 'Ever wanted to nail that rosetta? Learn to pour like a pro with our head barista. Your ticket includes coffee and a freshly baked pastry.',
    date: 'Saturday 22 March, 9am',
    icon: '☕',
  },
  {
    title: 'Seasonal Menu Launch',
    description: 'Be the first to taste our new Autumn menu. Complimentary tastings for the first 50 guests — arrive early to secure yours.',
    date: 'Friday 4 April, 12pm',
    icon: '✦',
  },
];
---

<Layout
  title="Visit Us & Order Catering | Kin & Grain Sydney CBD"
  description="Find Kin & Grain at 22 Market Street, near Wynyard Station. Check our hours, get directions, or enquire about catering for your next event. Contact us today."
>

  <!-- ═══ PAGE HEADER ════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 pt-16 pb-12 md:pt-24 md:pb-16 lg:pt-28 lg:pb-20 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <div class="lg:col-span-6">
          <p class="overline mb-4">Get in Touch</p>
          <h1 class="mb-6">Come Say Hello — We'd Love to See You</h1>
          <p class="leading-relaxed mb-4" style="color: var(--color-muted);">
            Whether you're popping in for your morning flat white or planning a catered event, your table is waiting. Drop by or get in touch below.
          </p>
          <div class="brush-stroke"></div>
        </div>
        <div class="lg:col-span-6">
          <div class="relative">
            <div class="rounded-lg overflow-hidden img-editorial shadow-lg shadow-ink/6">
              <img src="https://images.unsplash.com/photo-1600093463592-8e36ae95ef56?w=900&h=500&fit=crop" alt="Sunlit cafe corner with potted plants and natural wood furniture" class="w-full aspect-[16/9] object-cover img-sepia" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ LOCATION & MAP ═════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-stone);">
    <div class="grain-overlay absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-16 md:py-20 lg:py-24 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

        <!-- Left: Details (5 cols) -->
        <div class="lg:col-span-5 reveal">
          <p class="overline mb-3">Find Us</p>
          <h2 class="mb-8">Find Us &amp; Plan Your Visit</h2>

          <address class="not-italic space-y-4 mb-10">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-terracotta shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              <div>
                <p class="font-medium" style="color: var(--color-ink);">22 Market Street</p>
                <p style="color: var(--color-muted);">Sydney NSW 2000</p>
              </div>
            </div>
            <div class="space-y-2 pl-8">
              <p>
                <a href="tel:0295553421" class="link-underline hover:text-terracotta transition-colors duration-300" style="color: var(--color-ink);">
                  02 9555 3421
                </a>
              </p>
              <p>
                <a href="mailto:hello@kinandgrain.com.au" class="link-underline hover:text-terracotta transition-colors duration-300" style="color: var(--color-ink);">
                  hello@kinandgrain.com.au
                </a>
              </p>
            </div>
          </address>

          <div class="mb-10">
            <h3 class="mb-3">Hours</h3>
            <dl class="space-y-3">
              <div class="flex justify-between border-b pb-3" style="border-color: var(--color-warm-border);">
                <dt class="font-serif">Monday – Friday</dt>
                <dd class="tabular-nums font-medium">6:30am – 4pm</dd>
              </div>
              <div class="flex justify-between">
                <dt class="font-serif">Saturday – Sunday</dt>
                <dd class="tabular-nums font-medium">7:30am – 3pm</dd>
              </div>
            </dl>
          </div>

          <div>
            <h3 class="mb-3">How to Find Us</h3>
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-terracotta shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted);">Between Clarence &amp; Kent Streets, right in the heart of the CBD.</p>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-terracotta shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted);">Wynyard Station (5 min walk) or Town Hall (7 min walk).</p>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-4 h-4 text-terracotta shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
                <p class="text-sm leading-relaxed" style="color: var(--color-muted);">Street parking on Market St, or Westfield Sydney car park nearby.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Map (7 cols) -->
        <div class="lg:col-span-7 reveal">
          <div class="rounded-2xl overflow-hidden shadow-lg h-[400px] lg:h-full lg:min-h-[520px] border" style="border-color: var(--color-warm-border);">
            <iframe
              title="Kin & Grain location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.8!2d151.205!3d-33.870!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae3c3b3b3b3b%3A0x0!2s22+Market+St%2C+Sydney+NSW+2000!5e0!3m2!1sen!2sau!4v1700000000000!5m2!1sen!2sau"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ CATERING & EVENTS FORM ═════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 lg:py-[120px] relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

        <!-- Intro text (4 cols) -->
        <div class="lg:col-span-4 reveal">
          <p class="overline mb-3">Catering</p>
          <h2 class="mb-6">Let Us Cater Your Next Event</h2>
          <p class="leading-relaxed mb-6" style="color: var(--color-muted);">
            Planning a work function, birthday, or private celebration? Let us take the stress off your plate with bespoke catering packages for groups of 10 to 100.
          </p>
          <div class="brush-stroke mb-8"></div>

          <!-- Trust signals -->
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="text-terracotta text-sm mt-0.5">&#9679;</span>
              <p class="text-sm" style="color: var(--color-muted);">Menus tailored to your occasion and taste</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-terracotta text-sm mt-0.5">&#9679;</span>
              <p class="text-sm" style="color: var(--color-muted);">Full dietary accommodations — just let us know</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-terracotta text-sm mt-0.5">&#9679;</span>
              <p class="text-sm" style="color: var(--color-muted);">You'll hear back from us within 24 hours</p>
            </div>
          </div>
        </div>

        <!-- Form (8 cols) -->
        <div class="lg:col-span-8 reveal">
          <div class="card-warm p-6 md:p-10">
            <form id="catering-form" action="https://formspree.io/f/placeholder" method="POST" class="space-y-6">

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium mb-2">Name</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium mb-2">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="phone" class="block text-sm font-medium mb-2">Phone</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                  />
                </div>
                <div>
                  <label for="event-type" class="block text-sm font-medium mb-2">Event Type</label>
                  <select
                    id="event-type"
                    name="event_type"
                    required
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300 appearance-none"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink); background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%232C2825%22 stroke-width=%222%22%3E%3Cpath d=%22M6 9l6 6 6-6%22/%3E%3C/svg%3E'); background-repeat: no-repeat; background-position: right 1rem center;"
                  >
                    <option value="">Select type...</option>
                    <option value="corporate">Corporate Catering</option>
                    <option value="private">Private Function</option>
                    <option value="birthday">Birthday</option>
                    <option value="wedding">Wedding</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="guests" class="block text-sm font-medium mb-2">Estimated Guest Count</label>
                  <input
                    type="number"
                    id="guests"
                    name="guest_count"
                    min="10"
                    max="100"
                    placeholder="e.g. 30"
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                  />
                </div>
                <div>
                  <label for="date" class="block text-sm font-medium mb-2">Preferred Date</label>
                  <input
                    type="date"
                    id="date"
                    name="preferred_date"
                    class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300"
                    style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                  />
                </div>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 border rounded-[10px] text-sm transition-colors duration-300 resize-y"
                  style="background-color: var(--color-stone); border-color: var(--color-warm-border); color: var(--color-ink);"
                ></textarea>
              </div>

              <button type="submit" class="btn-primary">
                Send Your Enquiry
              </button>
            </form>

            <div id="catering-success" class="hidden py-12 text-center">
              <div class="brush-stroke mx-auto mb-6"></div>
              <h3 class="mb-3">Thank You!</h3>
              <p style="color: var(--color-muted);">We've received your enquiry and will be in touch within 24 hours. We're looking forward to making your event special.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ EVENTS ═════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-stone);">
    <div class="grain-overlay absolute inset-0"></div>

    <div class="max-w-[1200px] mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 lg:py-[120px] relative z-10">
      <div class="text-center mb-14 lg:mb-20 reveal">
        <p class="overline mb-4">What's On</p>
        <h2 class="mb-3">Upcoming Events You Won't Want to Miss</h2>
        <p class="max-w-[40ch] mx-auto text-sm" style="color: var(--color-muted);">Community, culture, and great coffee — there's always a reason to stop by.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
        {events.map((event, i) => (
          <article class={`card-warm p-8 lg:p-10 card-lift reveal stagger-${i + 1} ${i === 1 ? 'md:mt-8' : ''}`}>
            <span class="text-2xl mb-4 block text-terracotta/50">{event.icon}</span>
            <p class="overline mb-4">{event.date}</p>
            <h3 class="mb-4">{event.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
              {event.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══ SOCIAL CTA ═════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background-color: var(--color-cream);">
    <div class="paper-texture absolute inset-0"></div>

    <div class="max-w-[640px] mx-auto px-6 md:px-8 py-16 md:py-20 lg:py-24 text-center reveal relative z-10">
      <p class="overline mb-4">Community</p>
      <h2 class="mb-3">Join the Kin &amp; Grain Community</h2>
      <p class="text-sm mb-8 font-serif italic" style="color: var(--color-muted);">Behind the counter, on your plate, and in your neighbourhood</p>
      <a
        href="https://instagram.com/kinandgrain"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 btn-outline border-terracotta text-terracotta hover:bg-terracotta hover:text-white transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
        </svg>
        <span>Follow on Instagram</span>
      </a>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('catering-form') as HTMLFormElement;
  const success = document.getElementById('catering-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.classList.add('hidden');
    success?.classList.remove('hidden');
  });
</script>
